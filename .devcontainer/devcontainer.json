{
  "build": {
    "dockerfile": "./Dockerfile",
    "context": ".."
  },
  "remoteUser": "root",
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/root/.claude,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.config/opencode,target=/root/.config/opencode,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.local/share/opencode,target=/root/.local/share/opencode,type=bind,consistency=cached"
  ],
  "postCreateCommand": "task deps",
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "dprint.dprint",
        "emeraldwalk.runonsave"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "dprint.dprint",
        "[go]": {
          "editor.defaultFormatter": null,
          "editor.formatOnSave": false
        },
        "go.lintTool": "golangci-lint",
        "go.lintFlags": ["--fast"],
        "go.testFlags": ["-v"],
        "emeraldwalk.runonsave": {
          "commands": [
            {
              "match": "\\.go$",
              "cmd": "gofumpt -w -extra ${file} && golines -w ${file}"
            }
          ]
        }
      }
    }
  }
}
